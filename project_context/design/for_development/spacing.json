      ]
    },
    "sm": {
      "value": 8,
      "unit": "dp",
      "usage": "Малый отступ, icon padding",
      "examples": [
        "Отступ вокруг иконок",
        "Расстояние между связанными элементами",
        "Внутренние отступы в кнопках (вертикальный)"
      ]
    },
    "md": {
