{
  "version": "1.0.0",
  "lastUpdated": "2026-03-08",
  "description": "Система отступов для PassGen (согласно ТЗ раздел 2.4)",
  "spacingScale": {
    "xs": {
      "value": 4,
      "unit": "dp",
      "usage": "Минимальный отступ, tight spacing",
      "examples": [
        "Отступ между иконкой и текстом",
