  "flutterImplementation": {
    "theme": "textTheme: GoogleFonts.latoTextTheme(baseTheme.textTheme).copyWith(\n  displayLarge: TextStyle(fontSize: _fontSizeForWidth(57, 52, 48)),\n  headlineLarge: TextStyle(fontSize: _fontSizeForWidth(32, 30, 28)),\n  headlineMedium: TextStyle(fontSize: _fontSizeForWidth(28, 26, 24)),\n  titleLarge: TextStyle(fontSize: _fontSizeForWidth(22, 20, 18)),\n  titleMedium: TextStyle(fontSize: _fontSizeForWidth(16, 15, 15)),\n  bodyLarge: TextStyle(fontSize: _fontSizeForWidth(16, 15, 15)),\n  bodyMedium: TextStyle(fontSize: _fontSizeForWidth(14, 13, 13)),\n  labelLarge: TextStyle(fontSize: _fontSizeForWidth(14, 13, 13)),\n  labelSmall: TextStyle(fontSize: _fontSizeForWidth(11, 10, 10)),\n)",
    "helper": "// Helper function for responsive font sizes\ndouble _fontSizeForWidth(double desktop, double tablet, double mobile) {\n  final width = MediaQuery.of(context).size.width;\n  if (width >= Breakpoints.desktopMin) return desktop;\n  if (width >= Breakpoints.tabletMin) return tablet;\n  return mobile;\n}",
    "extension": "// Extension for responsive text (опционально)\nextension ResponsiveText on BuildContext {\n  double fontSizeForWidth(double desktop, double tablet, double mobile) {\n    final width = size.width;\n    if (width >= 900) return desktop;\n    if (width >= 600) return tablet;\n    return mobile;\n  }\n}"
  }
}
