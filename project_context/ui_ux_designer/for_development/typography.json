  "fontFamily": {
    "primary": "Lato",
    "fallback": "system-ui, -apple-system, sans-serif"
  },
  "googleFonts": {
    "package": "google_fonts",
    "import": "import 'package:google_fonts/google_fonts.dart';",
    "usage": "GoogleFonts.latoTextTheme(baseTheme.textTheme)"
  },
  "breakpoints": {
    "mobile": {
      "maxWidth": 599,
      "unit": "dp",
      "description": "Мобильные устройства"
    },
    "tablet": {
