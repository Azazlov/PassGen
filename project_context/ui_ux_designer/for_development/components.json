{
  "version": "1.1.0",
  "lastUpdated": "2026-03-08",
  "components": {
    "buttons": {
      "primary": {
        "widget": "ElevatedButton",
        "mobile": {
          "minHeight": 48,
          "minWidth": "fullWidth",
          "fontSize": 16,
          "padding": {
            "horizontal": 24,
            "vertical": 16
          }
        },
        "desktop": {
          "minHeight": 40,
          "minWidth": 200,
          "fontSize": 14,
          "padding": {
            "horizontal": 16,
            "vertical": 12
          }
        },
        "borderRadius": 8,
        "elevation": 2,
        "states": {
          "default": {
            "backgroundColor": "primary",
            "textColor": "onPrimary",
            "elevation": 2
          },
          "hover": {
            "backgroundColor": "primary + 10% brightness",
            "elevation": 4
          },
          "pressed": {
            "backgroundColor": "primary - 10% brightness",
            "elevation": 1
          },
          "disabled": {
            "backgroundColor": "outlineVariant",
            "textColor": "onDisabled",
            "opacity": 0.38,
            "elevation": 0
          },
          "loading": {
            "backgroundColor": "primary",
            "content": "CircularProgressIndicator (color: onPrimary, strokeWidth: 2)",
            "textColor": "onPrimary",
            "enabled": false
          }
        },
        "flutter": "ElevatedButton.styleFrom(\n  minimumSize: Size(width < 900 ? double.infinity : 200, height: width < 600 ? 48 : 40),\n  padding: EdgeInsets.symmetric(horizontal: width < 900 ? 24 : 16, vertical: width < 600 ? 16 : 12),\n  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8)),\n  elevation: 2,\n)"
      },
      "secondary": {
        "widget": "OutlinedButton",
        "mobile": {
          "minHeight": 48,
          "minWidth": "fullWidth",
          "fontSize": 16
        },
        "desktop": {
          "minHeight": 40,
          "minWidth": 200,
          "fontSize": 14
        },
        "padding": {
          "horizontal": 24,
          "vertical": 16
        },
        "borderRadius": 8,
        "borderWidth": 1,
        "borderColor": "outline",
        "states": {
          "default": {
            "backgroundColor": "transparent",
            "textColor": "primary",
            "borderColor": "outline"
          },
          "hover": {
            "backgroundColor": "primary.withOpacity(0.08)",
            "textColor": "primary",
            "borderColor": "primary"
          },
          "pressed": {
            "backgroundColor": "primary.withOpacity(0.12)",
            "textColor": "primary",
            "borderColor": "primary"
          },
          "disabled": {
            "backgroundColor": "transparent",
            "textColor": "onDisabled",
            "borderColor": "outlineVariant",
            "opacity": 0.38
          },
          "loading": {
            "backgroundColor": "transparent",
            "content": "CircularProgressIndicator (color: primary, strokeWidth: 2)",
            "textColor": "primary",
            "enabled": false
          }
        }
      },
      "text": {
        "widget": "TextButton",
        "minHeight": 48,
        "padding": {
          "horizontal": 12,
          "vertical": 8
        },
        "states": {
          "default": {
            "backgroundColor": "transparent",
            "textColor": "primary"
          },
          "hover": {
            "backgroundColor": "primary.withOpacity(0.08)"
          }
        }
      },
      "icon": {
        "widget": "IconButton",
        "size": 48,
        "iconSize": 24,
        "states": {
          "default": {
            "iconColor": "onSurface"
          },
          "hover": {
            "backgroundColor": "onSurface.withOpacity(0.08)"
          }
        }
      }
    },
    "textFields": {
      "standard": {
        "widget": "TextField",
        "height": 48,
        "borderRadius": 8,
        "borderWidth": 1,
        "padding": {
          "horizontal": 16,
          "vertical": 12
        },
        "states": {
          "default": {
            "borderColor": "outline"
          },
          "focused": {
            "borderColor": "primary",
            "borderWidth": 2
          },
          "error": {
            "borderColor": "error"
          },
          "disabled": {
            "opacity": 0.38,
            "borderColor": "outline"
          }
        },
        "flutter": "TextField(\n  decoration: InputDecoration(\n    labelText: 'Label',\n    hintText: 'Placeholder',\n    prefixIcon: Icon(Icons.icon),\n    border: OutlineInputBorder(borderRadius: BorderRadius.circular(8)),\n  ),\n)"
      },
      "password": {
        "extends": "standard",
        "suffixIcon": {
          "widget": "IconButton",
          "icon": "Icons.visibility_off",
          "onPressed": "toggleVisibility"
        }
      },
      "pin": {
        "cells": 8,
        "cellSize": 48,
        "cellGap": 8,
        "fillIndicator": {
          "type": "circle",
          "size": 8,
          "color": "primary"
        },
        "errorState": {
          "animation": "shake",
          "duration": 400,
          "iterations": 3,
          "color": "error"
        }
      }
    },
    "cards": {
      "standard": {
        "widget": "Card",
        "borderRadius": 12,
        "elevation": {
          "light": 1,
          "dark": 0
        },
        "padding": 16,
        "flutter": "Card(\n  elevation: 1,\n  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),\n  child: Padding(\n    padding: EdgeInsets.all(16),\n    child: Column(...),\n  ),\n)"
      }
    },
    "navigation": {
      "bottomNavigationBar": {
        "widget": "BottomNavigationBar",
        "height": 80,
        "iconSize": 24,
        "fontSize": 12,
        "type": "fixed",
        "showUnselectedLabels": true,
        "selectedItemColor": "primary",
        "unselectedItemColor": "onSurface.withOpacity(0.6)",
        "backgroundColor": "surface",
        "elevation": 8,
        "breakpoint": "< 600dp",
        "touchTarget": "48x48dp per item",
        "items": 5,
        "flutter": "BottomNavigationBar(\n  currentIndex: currentIndex,\n  onTap: onTabTapped,\n  type: BottomNavigationBarType.fixed,\n  selectedItemColor: theme.colorScheme.primary,\n  unselectedItemColor: theme.colorScheme.onSurface.withOpacity(0.6),\n  items: AppTab.values.map((tab) {\n    return BottomNavigationBarItem(\n      icon: Icon(tab.icon),\n      label: tab.label,\n      tooltip: tab.tooltip,\n    );\n  }).toList(),\n)"
      },
      "navigationRail": {
        "widget": "NavigationRail",
        "width": {
          "tablet": 72,
          "desktop": 80
        },
        "iconSize": {
          "tablet": 24,
          "desktop": 28
        },
        "labelType": "all",
        "backgroundColor": "surfaceContainerHighest",
        "selectedItemColor": "primary",
        "unselectedItemColor": "onSurface.withOpacity(0.6)",
        "breakpoint": "≥ 600dp",
        "touchTarget": "48x48dp per item",
        "flutter": "NavigationRail(\n  selectedIndex: currentIndex,\n  onDestinationSelected: onTabTapped,\n  labelType: NavigationRailLabelType.all,\n  backgroundColor: theme.colorScheme.surfaceContainerHighest,\n  selectedIconTheme: IconThemeData(color: theme.colorScheme.primary),\n  unselectedIconTheme: IconThemeData(\n    color: theme.colorScheme.onSurface.withOpacity(0.6),\n  ),\n  destinations: AppTab.values.map((tab) {\n    return NavigationRailDestination(\n      icon: Icon(tab.icon),\n      label: Text(tab.label),\n    );\n  }).toList(),\n)"
      },
      "sidebar": {
        "widget": "Sidebar (custom)",
        "width": {
          "desktop": 240,
          "wide": 280
        },
        "collapsible": {
          "desktop": true,
          "wide": false
        },
        "backgroundColor": "surfaceContainerHighest",
        "breakpoint": "≥ 900dp",
        "usage": "Filter panel, category list, navigation extensions"
      }
    },
    "passwordStrength": {
      "widget": "LinearProgressIndicator + Text",
      "segments": 5,
      "height": 8,
      "borderRadius": 4,
      "labels": [
        "Very Weak",
        "Weak",
        "Medium",
        "Strong",
        "Very Strong"
      ],
      "colors": {
        "veryWeak": "error",
        "weak": "warning",
        "medium": "warning",
        "strong": "success",
        "veryStrong": "success"
      },
      "animation": {
        "duration": 300,
        "curve": "Curves.easeInOut"
      }
    },
    "dialogs": {
      "alert": {
        "widget": "AlertDialog",
        "borderRadius": 12,
        "padding": 24,
        "actionsPadding": {
          "horizontal": 24,
          "vertical": 16
        },
        "buttonSpacing": 8
      },
      "confirm": {
        "extends": "alert",
        "actions": [
          {
            "label": "Cancel",
            "type": "text"
          },
          {
            "label": "Confirm",
            "type": "primary"
          }
        ]
      }
    },
    "feedback": {
      "snackbar": {
        "widget": "SnackBar",
        "height": 48,
        "borderRadius": 4,
        "duration": 4000,
        "actionTextColor": "secondary",
        "backgroundColor": "inverseSurface"
      },
      "progressIndicator": {
        "circular": {
          "widget": "CircularProgressIndicator",
          "strokeWidth": 4
        },
        "linear": {
          "widget": "LinearProgressIndicator",
          "height": 4,
          "borderRadius": 2
        }
      }
    }
  },
  "responsiveBreakpoints": {
    "mobile": {
      "max": 599,
      "layout": "single-column",
      "navigation": "bottom"
    },
    "tablet": {
      "min": 600,
      "max": 1023,
      "layout": "two-column",
      "navigation": "rail"
    },
    "desktop": {
      "min": 1024,
      "layout": "three-column",
      "navigation": "rail"
    }
  },
  "touchTargets": {
    "minimum": 48,
    "button": {
      "minWidth": 80,
      "minHeight": 48
    },
    "iconButton": {
      "size": 48
    },
    "checkbox": {
      "size": 48
    },
    "textField": {
      "minHeight": 48
    }
  },
  "accessibility": {
    "semantics": {
      "iconButton": {
        "required": ["label", "button"],
        "optional": ["hint"],
        "example": "Semantics(label: 'Копировать пароль', button: true, child: IconButton(...))"
      },
      "textField": {
        "required": ["label", "textField"],
        "optional": ["hint", "error"],
        "password": "obscured: true",
        "example": "Semantics(label: 'Пароль', textField: true, obscured: true, child: TextField(...))"
      },
      "card": {
        "required": ["label"],
        "optional": ["button", "selected"],
        "example": "Semantics(label: 'Пароль для Gmail, логин user@gmail', button: true, child: Card(...))"
      },
      "checkbox": {
        "required": ["label", "checked"],
        "optional": ["toggleable"],
        "example": "Semantics(label: 'Заглавные буквы', checked: true, toggleable: true, child: Checkbox(...))"
      },
      "switch": {
        "required": ["label", "checked"],
        "optional": ["toggleable"],
        "example": "Semantics(label: 'Тёмная тема', checked: false, toggleable: true, child: Switch(...))"
      }
    },
    "keyboardNavigation": {
      "tab": "Next focusable element",
      "shiftTab": "Previous focusable element",
      "enter": "Activate button / Submit form",
      "space": "Toggle switch / Activate button",
      "arrowUp": "Previous list item",
      "arrowDown": "Next list item",
      "arrowLeft": "Previous tab / Decrease slider",
      "arrowRight": "Next tab / Increase slider",
      "escape": "Close dialog / Cancel action",
      "delete": "Delete character / Delete item"
    },
    "focusIndicators": {
      "color": "primary",
      "width": "2dp",
      "shape": "RoundedRectangleBorder(borderRadius: 4dp)",
      "flutter": "FocusBorder(side: BorderSide(color: primary, width: 2))"
    },
    "contrastRequirements": {
      "normalText": "4.5:1 minimum (WCAG AA)",
      "largeText": "3:1 minimum (WCAG AA)",
      "uiComponents": "3:1 minimum (WCAG AA)",
      "focusIndicators": "3:1 minimum (WCAG AA)"
    },
    "checklist": {
      "screenReader": [
        "All IconButton have label and tooltip",
        "All TextField have label",
        "Password cards have descriptive label",
        "Checkbox/Switch have label and checked state",
        "Images have alt text (Semantics.label)"
      ],
      "keyboard": [
        "All interactive elements accessible via Tab",
        "Focus is visible (FocusBorder/FocusColor)",
        "Enter activates buttons",
        "Escape closes dialogs",
        "Arrow keys navigate lists"
      ],
      "visual": [
        "Contrast ≥ 4.5:1 for normal text",
        "Contrast ≥ 3:1 for UI components",
        "Focus indicators are visible",
        "Color is not the only way to convey information"
      ],
      "touch": [
        "All tap targets ≥ 48x48dp",
        "Buttons have sufficient padding",
        "Text fields ≥ 48dp height"
      ],
      "dynamicType": [
        "Text scales up to 200%",
        "Layout doesn't break at larger text sizes",
        "Content doesn't get clipped"
      ]
    }
  }
}
