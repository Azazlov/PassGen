sequenceDiagram
    %% ========================================================================
    %% PassGen — Sequence Diagram: Генерация и сохранение пароля
    %% Версия: 0.5.0
    %% Дата: 10 марта 2026
    %% ========================================================================

    autonumber

    participant U as "👤 Пользователь"
    participant UI as "🖥️ GeneratorScreen"
    participant C as "⚙️ GeneratorController"
    participant GUC as "📋 GeneratePasswordUseCase"
    participant PGR as "📦 PasswordGeneratorRepository"
    participant PGD as "🗄️ PasswordGeneratorLocalDataSource"
    participant CU as "🔐 CryptoUtils"
    participant PU as "📊 PasswordUtils"
    participant SUC as "💾 SavePasswordUseCase"
    participant PER as "🗃️ PasswordEntryRepository"
    participant DB as "💿 SQLite Database"
    participant LEUC as "📝 LogEventUseCase"
    participant SLR as "📜 SecurityLogRepository"

    %% ========================================================================
    %% ЧАСТЬ 1: ГЕНЕРАЦИЯ ПАРОЛЯ
    %% ========================================================================

    rect rgb(230, 240, 250)
        note over U,PGD: 🎲 ГЕНЕРАЦИЯ ПАРОЛЯ
    end

    U->>UI: Нажимает "Сгенерировать пароль"
    activate U
    activate UI

    UI->>C: generatePassword(settings)
    activate C

    C->>GUC: execute(settings)
    activate GUC

    GUC->>PGR: generatePassword(settings)
    activate PGR

    PGR->>PGD: generate(settings)
    activate PGD

    %% Генерация случайных байт
    PGD->>CU: generateRandomBytes(length)
    activate CU
    CU-->>PGD: случайные байты (CSPRNG)
    deactivate CU

    %% Формирование пароля
    PGD->>PGD: Применить наборы символов
    PGD->>PGD: Проверка уникальности (если включено)
    PGD->>PGD: Исключить похожие символы (если включено)
    PGD-->>PGR: PasswordResult(password, strength)
    deactivate PGD

    %% Оценка надёжности
    PGR->>PU: evaluateStrength(password)
    activate PU
    PU-->>PGR: score (0-4)
    deactivate PU

    PGR-->>GUC: PasswordResult
    deactivate PGR

    GUC-->>C: PasswordResult
    deactivate GUC

    C-->>UI: Обновить состояние (password, strength)
    deactivate C

    UI-->>U: Показать пароль + индикатор надёжности
    deactivate UI
    deactivate U

    %% ========================================================================
    %% ЧАСТЬ 2: СОХРАНЕНИЕ ПАРОЛЯ В ХРАНИЛИЩЕ
    %% ========================================================================

    rect rgb(230, 250, 240)
        note over U,DB: 💾 СОХРАНЕНИЕ ПАРОЛЯ
    end

    U->>UI: Вводит сервис, логин, нажимает "Сохранить"
    activate U
    activate UI

    UI->>C: savePassword(service, login, password, config, categoryId)
    activate C

    C->>SUC: execute(service, login, password, config, categoryId)
    activate SUC

    SUC->>PER: savePassword(entry)
    activate PER

    PER->>DB: BEGIN TRANSACTION
    activate DB

    %% Шифрование пароля
    PER->>CU: encrypt(password, key)
    activate CU
    CU-->>PER: encrypted_password + nonce
    deactivate CU

    %% Вставка записи в БД
    PER->>DB: INSERT INTO password_entries<br/>(category_id, service, login,<br/>encrypted_password, nonce,<br/>created_at, updated_at)
    DB-->>PER: entry_id

    %% Шифрование конфигурации
    PER->>CU: encrypt(config, key)
    activate CU
    CU-->>PER: encrypted_config
    deactivate CU

    %% Вставка конфигурации в БД
    PER->>DB: INSERT INTO password_configs<br/>(entry_id, strength, min_length,<br/>max_length, flags, require_unique,<br/>encrypted_config)
    DB-->>PER: config_id

    PER->>DB: COMMIT
    deactivate DB

    PER-->>SUC: success (entry_id)
    deactivate PER

    %% Логирование события PWD_CREATED
    SUC->>LEUC: execute(PWD_CREATED, details)
    activate LEUC

    LEUC->>SLR: logEvent(action, timestamp, details)
    activate SLR

    SLR->>DB: INSERT INTO security_logs<br/>(action_type, timestamp, details)
    activate DB
    DB-->>SLR: log_id
    deactivate DB

    SLR-->>LEUC: success
    deactivate SLR
    deactivate LEUC

    SUC-->>C: success (entry_id, config_id)
    deactivate SUC

    C-->>UI: Обновить состояние (успех)
    deactivate C

    UI-->>U: Показать уведомление "Пароль сохранён"
    deactivate UI
    deactivate U

    %% ========================================================================
    %% ЧАСТЬ 3: КОПИРОВАНИЕ ПАРОЛЯ (ОПЦИОНАЛЬНО)
    %% ========================================================================

    rect rgb(250, 240, 230)
        note over U,UI: 📋 КОПИРОВАНИЕ ПАРОЛЯ
    end

    U->>UI: Нажимает "Копировать пароль"
    activate U
    activate UI

    UI->>UI: Clipboard.setData(password)
    UI-->>U: Уведомление "Пароль скопирован"

    note over UI: ⏱️ Автоочистка буфера<br/>через 60 секунд
    UI->>UI: Clipboard.setData('')
    UI-->>U: Буфер очищен

    deactivate UI
    deactivate U

    %% ========================================================================
    %% ПРИМЕЧАНИЯ
    %% ========================================================================

    note right of U: "**Пользователь**<br/>- Инициирует генерацию<br/>- Настраивает параметры<br/>- Сохраняет пароль"

    note left of DB: "**SQLite База данных**<br/>- password_entries<br/>- password_configs<br/>- security_logs"

    note right of CU: "**CryptoUtils**<br/>- ChaCha20-Poly1305<br/>- PBKDF2 (10 000 итераций)<br/>- CSPRNG"

    note left of LEUC: "**Логирование событий**<br/>- PWD_CREATED<br/>- PWD_ACCESSED<br/>- PWD_DELETED<br/>- EXPORT/IMPORT"

    %% ========================================================================
    %% ЛЕГЕНДА
    %% ========================================================================
    %% 
    %% 🎲 ГЕНЕРАЦИЯ ПАРОЛЯ
    %% - Использование CSPRNG для криптографически стойких случайных чисел
    %% - Применение настроек (длина, наборы символов)
    %% - Оценка надёжности (zxcvbn + эвристика)
    %% 
    %% 💾 СОХРАНЕНИЕ ПАРОЛЯ
    %% - Шифрование ChaCha20-Poly1305 (AEAD)
    %% - Транзакционность (BEGIN/COMMIT)
    %% - Логирование события PWD_CREATED
    %% 
    %% 📋 КОПИРОВАНИЕ ПАРОЛЯ
    %% - Копирование в буфер обмена
    %% - Автоочистка через 60 секунд (v0.5.0)
    %% 
    %% ========================================================================
